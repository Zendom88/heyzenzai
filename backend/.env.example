# ──────────────────────────────────────────────
# Meta / WhatsApp
# ──────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=heyzenzai_webhook_secret

# ──────────────────────────────────────────────
# Google OAuth (Calendar)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.heyzenzai.com/oauth/callback

# For local testing only — the salon's refresh token
TEST_GOOGLE_REFRESH_TOKEN=

# ──────────────────────────────────────────────
# AI Provider
# ──────────────────────────────────────────────
AI_PROVIDER=gemini                # "gemini" or "openai"
GEMINI_API_KEY=
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
APP_ENV=development
OWNER_ALERT_PHONE=+65XXXXXXXX   # Your personal WhatsApp for escalation alerts
BASE_URL=https://api.heyzenzai.com
